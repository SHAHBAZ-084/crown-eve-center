// backend/prisma/schema.prisma
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Enums converted to Strings for SQLite compatibility

model User {
  id           String           @id @default(uuid())
  email        String           @unique
  password     String
  name         String
  phone        String?
  city         String?
  role         String           @default("CUSTOMER")
  branchId     Int?
  branch       Branch?          @relation(fields: [branchId], references: [id])
  orders       Order[]
  serviceBookings ServiceBooking[] @relation("CustomerBookings")
  tasks        ServiceBooking[] @relation("TechnicianTasks")
  createdAt    DateTime         @default(now())

  @@index([email])
  @@index([branchId])
}

model Branch {
  id           Int           @id @default(autoincrement())
  name         String
  location     String
  users        User[]
  products     Product[]
  inventory    Inventory[]
  orders       Order[]
  serviceBookings ServiceBooking[]
  services     Service[]
  purchases    Purchase[]
  adjustments  StockAdjustment[]
  walkInCustomers WalkInCustomer[]
  banks        Bank[]
  createdAt    DateTime      @default(now())
}

model Part {
  id           Int           @id @default(autoincrement())
  name         String
  category     String
  price        Float         // Selling price
  stock        Int           @default(0) // Central catalog stock or reference
  inventory    Inventory[]
  productParts ProductPart[]
  purchaseItems PurchaseItem[]
  adjustments  StockAdjustment[]
  createdAt    DateTime      @default(now())

  @@index([category])
}

model Product {
  id           String         @id @default(uuid())
  name         String
  slug         String         @unique
  product_type String         // 'bike' or 'part'
  description  String?
  price        Float          // Original price
  sale_price   Float?         // Sale price (optional)
  stock_qty    Int            @default(0)
  categoryId   String?
  category     Category?      @relation(fields: [categoryId], references: [id])
  brandId      String?
  brand        Brand?         @relation(fields: [brandId], references: [id])
  is_active    Boolean        @default(true)
  branchId     Int
  branch       Branch         @relation(fields: [branchId], references: [id])
  images       ProductImage[]
  bikeDetail   Bike?
  partDetail   PartDetail?
  orders       OrderItem[]
  productParts ProductPart[]
  createdAt    DateTime       @default(now())

  @@index([branchId])
  @@index([categoryId])
  @@index([brandId])
}

model Bike {
  id                    String  @id @default(uuid())
  productId             String  @unique
  product               Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  motor_type            String? // e.g. Multi Mode Motor
  motor_watt_min        Int?    // e.g. 3000W
  motor_watt_max        Int?    // e.g. 4000W
  battery_voltage       Float?  // e.g. 73.6V
  battery_capacity_ah   Float?  // e.g. 40Ah
  battery_type          String? // e.g. Lithium LFP
  speed_min_kmh         Float?  // e.g. 85 km/h
  speed_max_kmh         Float?  // e.g. 90 km/h
  range_eco_min_km      Int?    // e.g. 100 km
  range_eco_max_km      Int?    // e.g. 110 km
  speed_modes           Int?    // e.g. 4
  charger               String? // e.g. 72V10A
  charging_time_min_hrs Float?  // e.g. 4 hrs
  charging_time_max_hrs Float?  // e.g. 5 hrs
  net_weight_kg         Int?    // e.g. 100 kg
  loading_capacity_kg   Int?    // e.g. 200 kg
  security              String? // e.g. NFC Unlock
  braking_system        String? // e.g. F/R CBS
  color_options         Json?   // e.g. ["White","Blue","Red","Black","Grey"]
  frame_material        String? // Aluminium / Steel
  wheel_size            String? // e.g. 17"
  warranty              String? // e.g. 1 Year Battery
}

model PartDetail {
  id                  String  @id @default(uuid())
  productId           String  @unique
  product             Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  serial_no           Int?    // S/O number
  item_code           String? // e.g. SK-0104-FR
  model               String? // e.g. SPARK RD
  description         String? // Technical description
  cp_price            Float?  // Cost/Purchase price
  compatible_models   Json?   // e.g. ["SPARK RD", "ROBIN S-16"]
  compatible_bike_ids Json?   // FK references to bike product IDs
  unit                String? @default("piece") // piece, set, pair
}

model Category {
  id          String     @id @default(uuid())
  name        String     @unique
  parent_id   String?
  parent      Category?  @relation("SubCategories", fields: [parent_id], references: [id])
  children    Category[] @relation("SubCategories")
  description String?
  products    Product[]
  createdAt   DateTime   @default(now())
}

model Brand {
  id        String    @id @default(uuid())
  name      String    @unique
  country   String?
  city      String?
  contact   String?
  logo_url  String?
  products  Product[]
  createdAt DateTime  @default(now())
}

model ProductImage {
  id         String  @id @default(uuid())
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url        String
  is_primary Boolean @default(false)
  sort_order Int     @default(0)

  @@index([productId])
}

model ProductPart {
  id        Int     @id @default(autoincrement())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  partId    Int
  part      Part    @relation(fields: [partId], references: [id], onDelete: Cascade)
  quantity  Int     @default(1)

  @@index([productId])
  @@index([partId])
}

model Inventory {
  id       Int    @id @default(autoincrement())
  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id])
  partId   Int
  part     Part   @relation(fields: [partId], references: [id])
  stock    Int    @default(0)
  alertAt  Int    @default(5) // Threshold for alerts

  @@unique([branchId, partId])
  @@index([branchId])
  @@index([stock])
}

model Order {
  id         Int         @id @default(autoincrement())
  customerId String?
  customer   User?       @relation(fields: [customerId], references: [id])
  walkInCustomerId String?
  walkInCustomer   WalkInCustomer? @relation("WalkInOrders", fields: [walkInCustomerId], references: [id])
  branchId   Int
  branch     Branch      @relation(fields: [branchId], references: [id])
  bankId     String?
  bank       Bank?       @relation(fields: [bankId], references: [id])
  total      Float
  status         String @default("PENDING")
  type           String      @default("POS") // POS or ONLINE
  payment_method String      @default("CASH") // CASH, ACCOUNT, etc.
  transaction_id String?
  customer_name  String?
  customer_phone String?
  notes          String?
  items          OrderItem[]
  createdAt      DateTime    @default(now())

  @@index([branchId])
  @@index([status])
  @@index([createdAt])
  @@index([branchId, status])
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}

model Service {
  id                String           @id @default(uuid())
  name              String
  service_type      String           // maintenance / repair / installation
  description       String?
  base_price        Float
  duration_minutes  Int              @default(30)
  is_active         Boolean          @default(true)
  branchId          Int
  branch            Branch           @relation(fields: [branchId], references: [id])
  serviceCategoryId String?
  serviceCategory   ServiceCategory? @relation(fields: [serviceCategoryId], references: [id])
  checklist         Json?            @default("[]")
  bookings          ServiceBooking[]
}

model ServiceCategory {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  services    Service[]
  createdAt   DateTime  @default(now())
}

model ServiceBooking {
  id             String   @id @default(uuid())
  customerId     String
  customer       User     @relation("CustomerBookings", fields: [customerId], references: [id])
  serviceId      String
  service        Service  @relation(fields: [serviceId], references: [id])
  branchId       Int
  branch         Branch   @relation(fields: [branchId], references: [id])
  techId         String?
  technician     User?    @relation("TechnicianTasks", fields: [techId], references: [id])
  bike_product_id String?
  booking_date   DateTime
  booking_time   String
  status         String   @default("pending") // pending / confirmed / done / cancelled
  customer_notes String?
  final_price    Float?
  createdAt      DateTime @default(now())

  @@index([branchId])
  @@index([techId])
  @@index([booking_date])
}

model Supplier {
  id        Int        @id @default(autoincrement())
  name      String
  contact   String
  purchases Purchase[]
}

model Purchase {
  id         Int            @id @default(autoincrement())
  supplierId Int
  supplier   Supplier       @relation(fields: [supplierId], references: [id])
  branchId   Int
  branch     Branch         @relation(fields: [branchId], references: [id])
  total      Float
  items      PurchaseItem[]
  createdAt  DateTime       @default(now())

  @@index([branchId])
}

model PurchaseItem {
  id         Int      @id @default(autoincrement())
  purchaseId Int
  purchase   Purchase @relation(fields: [purchaseId], references: [id])
  partId     Int
  part       Part     @relation(fields: [partId], references: [id])
  quantity   Int
  cost       Float
}
model StockAdjustment {
  id        Int      @id @default(autoincrement())
  branchId  Int
  branch    Branch   @relation(fields: [branchId], references: [id])
  partId    Int
  part      Part     @relation(fields: [partId], references: [id])
  quantity  Int      // Positive for In, Negative for Out
  reason    String?  // e.g. "Manual Update", "Damaged", "Correction"
  createdAt DateTime @default(now())

  @@index([branchId])
  @@index([createdAt])
}

model Testimonial {
  id         String   @id @default(uuid())
  name       String
  role       String?
  text       String
  stars      Int      @default(5)
  isApproved Boolean  @default(true) 
  createdAt  DateTime @default(now())
}

model WalkInCustomer {
  id         String   @id @default(uuid())
  first_name String
  last_name  String
  cnic       String
  phone      String
  whatsapp   String?
  address    String
  email      String?
  branchId   Int
  branch     Branch   @relation(fields: [branchId], references: [id])
  orders     Order[]  @relation("WalkInOrders")
  createdAt  DateTime @default(now())

  @@index([branchId])
  @@index([phone])
}

model Bank {
  id             String   @id @default(uuid())
  name           String
  account_title  String
  account_number String
  iban           String?
  branch_name    String?
  initial_balance Float    @default(0)
  current_balance Float    @default(0)
  branchId       Int
  branch         Branch   @relation(fields: [branchId], references: [id])
  orders         Order[]
  createdAt      DateTime @default(now())

  @@index([branchId])
}
