// backend/prisma/schema.prisma
generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Enums converted to Strings for SQLite compatibility

model User {
  id           String           @id @default(uuid())
  email        String           @unique
  password     String
  name         String
  phone        String?
  city         String?
  role         String           @default("CUSTOMER")
  branchId     Int?
  branch       Branch?          @relation(fields: [branchId], references: [id])
  orders       Order[]
  serviceBookings ServiceBooking[] @relation("CustomerBookings")
  tasks        ServiceBooking[] @relation("TechnicianTasks")
  createdAt    DateTime         @default(now())

  @@index([email])
  @@index([branchId])
}

model Branch {
  id           Int           @id @default(autoincrement())
  name         String
  location     String
  users        User[]
  products     Product[]
  inventory    Inventory[]
  orders       Order[]
  serviceBookings ServiceBooking[]
  services     Service[]
  purchases    Purchase[]
  createdAt    DateTime      @default(now())
}

model Part {
  id           Int           @id @default(autoincrement())
  name         String
  category     String
  price        Float         // Selling price
  stock        Int           @default(0) // Central catalog stock or reference
  inventory    Inventory[]
  productParts ProductPart[]
  purchaseItems PurchaseItem[]
  createdAt    DateTime      @default(now())

  @@index([category])
}

model Product {
  id           String         @id @default(uuid())
  name         String
  slug         String         @unique
  product_type String         // 'bike' or 'part'
  description  String?
  price        Float          // Original price
  sale_price   Float?         // Sale price (optional)
  stock_qty    Int            @default(0)
  categoryId   String?
  category     Category?      @relation(fields: [categoryId], references: [id])
  brandId      String?
  brand        Brand?         @relation(fields: [brandId], references: [id])
  is_active    Boolean        @default(true)
  branchId     Int
  branch       Branch         @relation(fields: [branchId], references: [id])
  images       ProductImage[]
  bikeDetail   Bike?
  partDetail   PartDetail?
  orders       OrderItem[]
  productParts ProductPart[]
  createdAt    DateTime       @default(now())

  @@index([branchId])
  @@index([categoryId])
  @@index([brandId])
}

model Bike {
  id               String  @id @default(uuid())
  productId        String  @unique
  product          Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  motor_type       String? // Hub / Mid-Drive / BLDC
  motor_watt       Int?
  battery_capacity_wh Int?
  range_km         Float?
  top_speed_kmh    Float?
  frame_material   String?
  brake_type       String?
  wheel_size       String?
  payload_kg       Int?
  color            String?
  warranty         String?
}

model PartDetail {
  id                String  @id @default(uuid())
  productId         String  @unique
  product           Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku               String? @unique
  part_number       String?
  compatible_models String?
  part_category     String?
  unit              String? // piece, set, pair
}

model Category {
  id          String     @id @default(uuid())
  name        String     @unique
  parent_id   String?
  parent      Category?  @relation("SubCategories", fields: [parent_id], references: [id])
  children    Category[] @relation("SubCategories")
  description String?
  products    Product[]
  createdAt   DateTime   @default(now())
}

model Brand {
  id        String    @id @default(uuid())
  name      String    @unique
  country   String?
  logo_url  String?
  products  Product[]
  createdAt DateTime  @default(now())
}

model ProductImage {
  id         String  @id @default(uuid())
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url        String
  is_primary Boolean @default(false)
  sort_order Int     @default(0)

  @@index([productId])
}

model ProductPart {
  id        Int     @id @default(autoincrement())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  partId    Int
  part      Part    @relation(fields: [partId], references: [id], onDelete: Cascade)
  quantity  Int     @default(1)

  @@index([productId])
  @@index([partId])
}

model Inventory {
  id       Int    @id @default(autoincrement())
  branchId Int
  branch   Branch @relation(fields: [branchId], references: [id])
  partId   Int
  part     Part   @relation(fields: [partId], references: [id])
  stock    Int    @default(0)
  alertAt  Int    @default(5) // Threshold for alerts

  @@unique([branchId, partId])
  @@index([branchId])
  @@index([stock])
}

model Order {
  id         Int         @id @default(autoincrement())
  customerId String?
  customer   User?       @relation(fields: [customerId], references: [id])
  branchId   Int
  branch     Branch      @relation(fields: [branchId], references: [id])
  total      Float
  status     String @default("PENDING")
  type       String      @default("POS") // POS or ONLINE
  notes      String?
  items      OrderItem[]
  createdAt  DateTime    @default(now())

  @@index([branchId])
  @@index([status])
  @@index([createdAt])
  @@index([branchId, status])
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}

model Service {
  id                String           @id @default(uuid())
  name              String
  service_type      String           // maintenance / repair / installation
  description       String?
  base_price        Float
  duration_minutes  Int              @default(30)
  is_active         Boolean          @default(true)
  branchId          Int
  branch            Branch           @relation(fields: [branchId], references: [id])
  serviceCategoryId String?
  serviceCategory   ServiceCategory? @relation(fields: [serviceCategoryId], references: [id])
  bookings          ServiceBooking[]
}

model ServiceCategory {
  id          String    @id @default(uuid())
  name        String    @unique
  description String?
  services    Service[]
  createdAt   DateTime  @default(now())
}

model ServiceBooking {
  id             String   @id @default(uuid())
  customerId     String
  customer       User     @relation("CustomerBookings", fields: [customerId], references: [id])
  serviceId      String
  service        Service  @relation(fields: [serviceId], references: [id])
  branchId       Int
  branch         Branch   @relation(fields: [branchId], references: [id])
  techId         String?
  technician     User?    @relation("TechnicianTasks", fields: [techId], references: [id])
  bike_product_id String?
  booking_date   DateTime
  booking_time   String
  status         String   @default("pending") // pending / confirmed / done / cancelled
  customer_notes String?
  final_price    Float?
  createdAt      DateTime @default(now())

  @@index([branchId])
  @@index([techId])
  @@index([booking_date])
}

model Supplier {
  id        Int        @id @default(autoincrement())
  name      String
  contact   String
  purchases Purchase[]
}

model Purchase {
  id         Int            @id @default(autoincrement())
  supplierId Int
  supplier   Supplier       @relation(fields: [supplierId], references: [id])
  branchId   Int
  branch     Branch         @relation(fields: [branchId], references: [id])
  total      Float
  items      PurchaseItem[]
  createdAt  DateTime       @default(now())

  @@index([branchId])
}

model PurchaseItem {
  id         Int      @id @default(autoincrement())
  purchaseId Int
  purchase   Purchase @relation(fields: [purchaseId], references: [id])
  partId     Int
  part       Part     @relation(fields: [partId], references: [id])
  quantity   Int
  cost       Float
}
